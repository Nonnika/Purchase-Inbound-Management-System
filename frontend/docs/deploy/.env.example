# =============================================================================
# PIMS 部署环境变量示例
# 用法：复制为 .env 后修改（本文件放在仓库根目录，与 docker-compose.yml 同级）
# =============================================================================

# 数据库名（须与 init.sql 使用的库一致；MySQL 容器会自动创建该库）
DB_NAME=pims

# 数据库 root 密码（部署时务必改为强密码，且与后端 DB_PASSWD 一致）
DB_PASSWD=change-me-to-a-strong-password

# Web 对外端口（Nginx），默认 80
WEB_PORT=80

# JWT 配置
# JWT_SECRET 必须 >= 32 字节，否则后端启动会 log.Fatal
JWT_SECRET=replace-with-at-least-32-bytes-random-secret-xxxxxx
JWT_ISSUER=Nonnika.Y
